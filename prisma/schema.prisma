// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  displayName  String
  accessMode   String   @default("SERVICE")
  isDeleted    Boolean  @default(false)
  isDisabled   Boolean  @default(false)
  canClaimOrders Boolean @default(true)
  preciseClaimLimit Int?
  serviceClaimLimit Int?
  tenantId     Int?
  roleId       Int
  storeId      Int?
  longitude    Float?
  latitude     Float?
  locationAt   DateTime?
  lastLoginAt  DateTime?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  store        Store?   @relation("StoreMembers", fields: [storeId], references: [id], onDelete: SetNull)
  dispatches   DispatchOrder[] @relation("CreatedOrders")
  claimedOrders DispatchOrder[] @relation("ClaimedOrders")
  convertedPreciseOrders DispatchOrder[] @relation("ConvertedPreciseOrders")
  dispatchRecords DispatchOrderRecord[]
  managedStores Store[]   @relation("StoreManager")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Role {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  name      String
  tenantId  Int?
  isBuiltin Boolean    @default(false)
  dataScope String     @default("TENANT")
  tenant    Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users     User[]
  roleMenus RoleMenu[]
}

model Menu {
  id         Int        @id @default(autoincrement())
  key        String     @unique
  name       String
  path       String
  icon       String?
  sort       Int        @default(0)
  parentId   Int?
  parent     Menu?      @relation("MenuTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   Menu[]     @relation("MenuTree")
  roleMenus  RoleMenu[]
}

model RoleMenu {
  roleId Int
  menuId Int
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu   Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([roleId, menuId])
}

model Package {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  name        String
  code        String   @unique
  price       Float
  description String?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dispatches  DispatchOrder[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DispatchOrder {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  title         String
  region        String
  address       String
  longitude     Float?
  latitude      Float?
  phone         String
  customerType  String
  remark        String?
  appointmentAt DateTime?
  handledPhone  String?
  notHandledReason String?
  isImportant    Boolean  @default(false)
  photoUrl      String?
  isDeleted     Boolean  @default(false)
  status        String   @default("PENDING")
  packageId     Int?
  package       Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById   Int
  createdBy     User     @relation("CreatedOrders", fields: [createdById], references: [id], onDelete: Restrict)
  claimedById   Int?
  claimedBy     User?    @relation("ClaimedOrders", fields: [claimedById], references: [id], onDelete: SetNull)
  claimedAt     DateTime?
  convertedToPreciseById Int?
  convertedToPreciseBy User? @relation("ConvertedPreciseOrders", fields: [convertedToPreciseById], references: [id], onDelete: SetNull)
  convertedToPreciseAt DateTime?
  records       DispatchOrderRecord[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DispatchOrderRecord {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  orderId    Int
  order      DispatchOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  operatorId Int
  operator   User     @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actionType String
  remark     String?
  photoUrl   String?
  operatorLongitude Float?
  operatorLatitude  Float?
  createdAt  DateTime @default(now())
}

model Tenant {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  roles     Role[]
  users     User[]
  packages  Package[]
  orders    DispatchOrder[]
  records   DispatchOrderRecord[]
  stores    Store[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Store {
  id            Int      @id @default(autoincrement())
  tenantId       Int
  name           String
  managerUserId  Int
  isDeleted      Boolean  @default(false)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager        User     @relation("StoreManager", fields: [managerUserId], references: [id], onDelete: Restrict)
  users          User[]   @relation("StoreMembers")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([managerUserId])
}
