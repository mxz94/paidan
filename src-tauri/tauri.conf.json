{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "paidan",
  "version": "0.1.0",
  "identifier": "com.paidan.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../src-tauri/web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "paidan",
        "width": 1366,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/icon.ico"
    ]
  }
}